          "expr": "sum by (volume, pvc, pvc_namespace) ((1 - miroir_volume_up_to_date{pvc=~\"$pvc\", pool=~\"$pool\"}) OR (1 - miroir_volume_connected{pvc=~\"$pvc\", pool=~\"$pool\"}))",
