          "expr": "max by (volume, pvc, pvc_namespace) (miroir_volume_out_of_sync_bytes{pvc=~\"$pvc\", pool=~\"$pool\"})",
          "refId": "A",
          "legendFormat": "{{pvc_namespace}}/{{pvc}}"
        }
